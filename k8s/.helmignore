# Helm ignore file
# Patterns listed here will be excluded from the chart package (.tgz)

# Git metadata
.git/
.gitignore
.gitattributes
.github/

# Documentation (not needed in the packaged chart)
*.md
README.md

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# CI/CD
.travis.yml
.circleci/

# Test files
tests/
test/
