# Helm ignore file

# Patterns listed here will be excluded from the chart package (.tgz)

# Git metadata

.git/
.gitignore
.gitattributes
.github/

# Documentation (not needed in the packaged chart)

\*.md
README.md

# Large runtime assets are applied as standalone ConfigMaps before Helm install/upgrade.

assets/

# Editor and IDE files

.vscode/
.idea/
_.swp
_.swo
\*~

# OS files

.DS_Store
Thumbs.db

# CI/CD

.travis.yml
.circleci/

# Test files

tests/
test/
