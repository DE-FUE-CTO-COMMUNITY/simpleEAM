# ============================================================================
# NextGen EAM Environment Configuration Template
# ============================================================================
# Copy this file to .env and adjust the values according to your environment.
# For development, you may also create client/.env.local for local overrides.
#
# IMPORTANT: Never commit the .env file with actual credentials to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Branding
# ----------------------------------------------------------------------------

# Full application name (displayed in header and page titles)
BRAND_NAME_LONG=NextGen Enterprise Architecture Management

# Short application name (used in logo alt text, welcome messages, etc.)
BRAND_NAME_SHORT=NextGen EAM

# ----------------------------------------------------------------------------
# General Settings
# ----------------------------------------------------------------------------

# Base domain for all services (e.g., example.com, localhost, your-domain.com)
# This is combined with subdomains to form complete URLs
BASE_DOMAIN=example.com

# Favicon URL (path to favicon file in public folder)
FAVICON_URL=/favicon.ico

# Sidebar drawer width in pixels (runtime variable - can be changed without rebuild)
DRAWER_WIDTH=240

# Traefik certificate resolver name (for automatic HTTPS certificates)
# Leave as-is if using netcup DNS challenge, or configure your own resolver
TRAEFIK_CERTRESOLVER=my-traefik-cert-resolver

# Docker network name for Traefik reverse proxy
TRAEFIK_NETWORK=traefik-network

# Docker Compose project name (used as prefix for container names)
COMPOSE_PROJECT_NAME=nextgen-eam

# ----------------------------------------------------------------------------
# Service Subdomains
# ----------------------------------------------------------------------------
# These subdomains are combined with BASE_DOMAIN to create service URLs

# Neo4j database browser subdomain (e.g., neo4j.example.com)
NEO4J_SUBDOMAIN=neo4j

# GraphQL API subdomain (e.g., api.example.com)
API_SUBDOMAIN=api

# Keycloak authentication subdomain (e.g., auth.example.com)
AUTH_SUBDOMAIN=auth

# Next.js client application subdomain (e.g., eam.example.com)
CLIENT_SUBDOMAIN=eam

# Excalidraw collaboration room subdomain (e.g., room.example.com)
EXCALIDRAW_ROOM_SUBDOMAIN=room

# Temporal UI subdomain (e.g., temporal.example.com)
TEMPORAL_UI_SUBDOMAIN=temporal

# Optional dedicated cert resolver for Temporal UI.
# Use this when your BASE_DOMAIN zone is managed by another DNS provider
# than the global TRAEFIK_CERTRESOLVER (e.g., cloudflaredns).
TEMPORAL_UI_CERTRESOLVER=my-traefik-cert-resolver

# ----------------------------------------------------------------------------
# Neo4j Database Configuration
# ----------------------------------------------------------------------------

# Neo4j database username
NEO4J_USER=neo4j

# Neo4j database password (change this for production!)
NEO4J_PASSWORD=my-secret-eam-password

# Neo4j authentication string (automatically constructed from user/password)
NEO4J_AUTH=${NEO4J_USER}/${NEO4J_PASSWORD}

# Neo4j Bolt connection URI (internal Docker network)
# Format: bolt://hostname:port
NEO4J_URI=bolt://neo4j:7687

# Neo4j memory settings
NEO4J_PAGECACHE_MEMORY=1G          # Page cache memory allocation
NEO4J_HEAP_INITIAL_SIZE=1G         # Initial JVM heap size
NEO4J_HEAP_MAX_SIZE=2G             # Maximum JVM heap size

# Neo4j internal ports (within Docker network)
NEO4J_PORT=7474                    # HTTP port for browser interface
NEO4J_BOLT_PORT=7687               # Bolt protocol port for database connections

# Neo4j external ports (exposed on host machine)
NEO4J_EXTERNAL_PORT=7474           # External HTTP port
NEO4J_EXTERNAL_BOLT_PORT=7687      # External Bolt port

# ----------------------------------------------------------------------------
# Keycloak Authentication Configuration
# ----------------------------------------------------------------------------

# Full Keycloak URL (including protocol and subdomain)
KEYCLOAK_URL=https://${AUTH_SUBDOMAIN}.${BASE_DOMAIN}

# Keycloak admin console credentials (change for production!)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=my-secret-keycloak-password

# Keycloak ports
KEYCLOAK_INTERNAL_PORT=8080        # Internal Docker port
KEYCLOAK_EXTERNAL_PORT=8280        # External host port

# Keycloak realm name (organizational unit for users/applications)
KEYCLOAK_REALM=nextgen-eam

# Keycloak client IDs
KEYCLOAK_CLIENT_ID_SERVER=eam-server    # Server-side client (GraphQL API)
KEYCLOAK_CLIENT_ID_CLIENT=eam-client    # Client-side client (Next.js app)

# Keycloak Database (PostgreSQL) Configuration
KC_DB=postgres                               # Database type
KC_DB_NAME=keycloak                          # Database name
KC_DB_USER=keycloak                          # Database user
KC_DB_PASSWORD=secret-keycloak-db-password   # Database password (change for production!)

# ----------------------------------------------------------------------------
# GraphQL API Server Configuration
# ----------------------------------------------------------------------------

# Full GraphQL API URL (including protocol, subdomain, and path)
GRAPHQL_URL=https://${API_SUBDOMAIN}.${BASE_DOMAIN}/graphql

# GraphQL server ports
GRAPHQL_INTERNAL_PORT=4000         # Internal Docker port
GRAPHQL_EXTERNAL_PORT=4000         # External host port

# AI server ports (dedicated REST API for AI workflows)
AI_SERVER_INTERNAL_PORT=4001       # Internal Docker port
AI_SERVER_EXTERNAL_PORT=4001       # External host port

# AI API base URL consumed by the frontend (without /ai-runs suffix)
# Defaults to https://${API_SUBDOMAIN}.${BASE_DOMAIN} if not set (constructed by compose.yml).
# Override only if the AI server is reachable at a different URL.
AI_API_URL=

# ----------------------------------------------------------------------------
# Analytics Stack Configuration
# ----------------------------------------------------------------------------

# Enables the analytics workspace in the client runtime configuration.
ANALYTICS_ENABLED=true

# Cube.js API base URL consumed by the analytics workspace.
# Defaults to the authenticated analytics backend on the API subdomain.
ANALYTICS_API_URL=https://${API_SUBDOMAIN}.${BASE_DOMAIN}/analytics

# Internal Cube.js API base URL used by the analytics backend and exposed for diagnostics.
ANALYTICS_CUBE_API_URL=http://cube:4000/cubejs-api/v1

# ClickHouse database used as projection store for analytics queries.
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=nextgen_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTP_EXTERNAL_PORT=8123
CLICKHOUSE_NATIVE_EXTERNAL_PORT=9000

# Cube.js service settings.
CUBEJS_EXTERNAL_PORT=4003
CUBEJS_API_SECRET=nextgen-eam-analytics-dev
CUBEJS_DEV_MODE=true
CUBEJS_WEB_SOCKETS=true

# ----------------------------------------------------------------------------
# Next.js Client Configuration
# ----------------------------------------------------------------------------

# Next.js client application port
CLIENT_PORT=3000
CLIENT_EXTERNAL_PORT=3000

# Node.js environment (development, production, test)
# Set to 'production' for Docker deployments
NODE_ENV=production

# ----------------------------------------------------------------------------
# Excalidraw Collaboration Server
# ----------------------------------------------------------------------------

# WebSocket server URL for real-time diagram collaboration
EXCALIDRAW_WS_SERVER_URL=https://${EXCALIDRAW_ROOM_SUBDOMAIN}.${BASE_DOMAIN}
EXCALIDRAW_ROOM_PORT=80
EXCALIDRAW_ROOM_EXTERNAL_PORT=4002


# ----------------------------------------------------------------------------
# Temporal (Self-hosted) Configuration
# ----------------------------------------------------------------------------

# Temporal gRPC endpoint exposed on host
TEMPORAL_EXTERNAL_PORT=7233

# Temporal address for server/worker communication
TEMPORAL_ADDRESS=temporal:7233

# Temporal namespace used for AI workflows
TEMPORAL_NAMESPACE=default

# Temporal task queue for AI run workflows
AI_RUN_TASK_QUEUE=nextgen-eam-ai

# LLM request timeout in milliseconds (important for slower local inference).
AI_LLM_TIMEOUT_MS=45000

# Number of retries for LLM requests after transient failures/timeouts.
AI_LLM_RETRY_COUNT=1

# If true, logs a preview of the effective LLM prompt in worker logs (debug only).
AI_LOG_LLM_PROMPT=false

# Maximum number of prompt characters included in the debug preview log.
AI_LLM_PROMPT_LOG_PREVIEW_CHARS=1200

# If true, run completes with template fallback when LLM fails.
# If false (recommended), LLM failure marks run as FAILED.
AI_ALLOW_LLM_FALLBACK=false

# Number of web sources used for strategic enrichment context.
AI_WEB_SOURCE_COUNT=4

# Number of search candidates collected before source filtering.
AI_WEB_SEARCH_RESULT_COUNT=16

# Timeout in milliseconds for web research fetches.
AI_WEB_FETCH_TIMEOUT_MS=12000

# Ordered search providers for company-first discovery.
# Supported: duckduckgo_html, duckduckgo_lite, wikipedia_api, searxng
AI_SEARCH_PROVIDERS=duckduckgo_html,duckduckgo_lite,wikipedia_api

# Optional SearXNG endpoint for robust API-based search fallback.
# Example: https://searxng.example.com/search
AI_SEARCH_SEARXNG_URL=

# Optional API key/token for protected SearXNG deployments.
AI_SEARCH_SEARXNG_API_KEY=

# Optional dedicated client credentials for AgentConfig startup bootstrap.
# If left empty, ai-server falls back to KEYCLOAK_CLIENT_ID_SERVER + KEYCLOAK_CLIENT_SECRET_SERVER.
# The client must be allowed to request client_credentials tokens and have admin rights in realm roles.
AI_AGENT_CONFIG_BOOTSTRAP_CLIENT_ID=
AI_AGENT_CONFIG_BOOTSTRAP_CLIENT_SECRET=

# Analytics projection refresh endpoint used by the Temporal worker.
ANALYTICS_SYNC_URL=http://server:${GRAPHQL_INTERNAL_PORT}/analytics/projections/sync

# Enables automatic registration of a Temporal schedule that refreshes analytics projections.
ANALYTICS_PROJECTION_SCHEDULE_ENABLED=false

# Stable Temporal schedule id for analytics projection refreshes.
ANALYTICS_PROJECTION_SCHEDULE_ID=analytics-projection-refresh

# Temporal schedule interval. Examples: 30 minutes, 1 hour, 12 hours.
ANALYTICS_PROJECTION_SCHEDULE_INTERVAL=1 hour

# Maximum number of company projection refreshes processed in parallel by one workflow run.
ANALYTICS_PROJECTION_MAX_CONCURRENCY=5

# Temporal UI host port
TEMPORAL_UI_EXTERNAL_PORT=8088

# Temporal persistence database settings
TEMPORAL_DB_NAME=temporal
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=temporal

# ----------------------------------------------------------------------------
# Theme and Branding Configuration
# ----------------------------------------------------------------------------

# Primary theme color (Material UI primary palette)
# Format: Hex color code (e.g., #00BCD4 for cyan) - must be quoted!
THEME_PRIMARY_COLOR="#00BCD4"

# Secondary theme color (Material UI secondary palette)
# Format: Hex color code (e.g., #4E342E for brown) - must be quoted!
THEME_SECONDARY_COLOR="#4E342E"

# Theme font family (CSS font-family value)
# Format: Comma-separated font names with fallbacks (without quotes in .env)
THEME_FONT_FAMILY=Roboto, Helvetica, Arial, sans-serif

# Logo configuration
LOGO_URL=/images/NextGen-EAM-Logo.svg   # Path to logo file (relative to public/)
LOGO_ALT=NextGen EAM Logo               # Alt text for accessibility
LOGO_LENGTH=120                         # Logo width in pixels (max 184px, height is fixed at 30px)
LOGO_DARK_URL=                          # Optional: path to dark mode logo (relative to public/), falls back to LOGO_URL

# ============================================================================
# Development Notes
# ============================================================================
#
# Local Development:
# - For local development without Docker, create client/.env.local with:
#   KEYCLOAK_URL=http://localhost:8280
#   GRAPHQL_URL=http://localhost:4500/graphql
#   EXCALIDRAW_WS_SERVER_URL=http://localhost:3002
#
# Runtime Configuration:
# - All client-side configuration is loaded at runtime via /api/runtime-config
# - No NEXT_PUBLIC_ variables are used (no build-time configuration)
# - Changes to these variables take effect immediately without rebuilding
#
# Docker Deployment:
# - Ensure .env file exists in project root
# - Run: docker-compose up -d
# - Services will be available at their configured subdomains
# - AI services are profile-based and disabled by default
# - To enable AI stack: set AI_LLM_URL and run with COMPOSE_PROFILES=ai
#
# Security Recommendations:
# - Change all default passwords for production deployments
# - Use strong passwords for NEO4J_PASSWORD and KEYCLOAK_ADMIN_PASSWORD
# - Configure proper SSL/TLS certificates via Traefik
# - Restrict external port access via firewall rules
# - Use secrets management for sensitive values in production
#
# ============================================================================
