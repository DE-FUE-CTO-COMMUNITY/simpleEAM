{
  "name": "nextgen-eam-ai-server",
  "version": "1.3.2",
  "description": "NextGen EAM AI server",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath && process.env.npm_execpath.indexOf('yarn') === -1) throw new Error('⚠️ Please use yarn for this project!')\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "echo \"No ai-server tests configured\"",
    "worker": "node dist/agents/worker.js",
    "worker:dev": "ts-node-dev --respawn --transpile-only src/agents/worker.ts",
    "generate-schema-digest": "node scripts/generate-schema-digest.mjs",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "packageManager": "yarn@4.9.1",
  "dependencies": {
    "@langchain/core": "^1.1.26",
    "@langchain/langgraph": "^1.1.5",
    "@temporalio/client": "^1.11.6",
    "@temporalio/worker": "^1.11.6",
    "@temporalio/workflow": "^1.11.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-client": "^2.0.5",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.8.2",
    "@types/uuid": "^9.0.4",
    "dotenv-expand": "^12.0.3",
    "graphql": "^16.13.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
