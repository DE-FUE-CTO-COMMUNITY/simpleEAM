<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_Manufacture_Modules"
  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="process_manufacture_modules" name="Manufacture Modules" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Manufacture">
      <bpmn:lane id="Lane_Planning" name="Planning">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Production" name="Production">
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Quality" name="Quality Assurance">
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Production order received" />
    <bpmn:task id="Task_1" name="Review BOM and specifications" />
    <bpmn:task id="Task_2" name="Schedule work center capacity" />
    <bpmn:task id="Task_3" name="Issue material to assembly line" />
    <bpmn:task id="Task_4" name="Assemble module components" />
    <bpmn:exclusiveGateway id="Gateway_1" name="Quality pass?" />
    <bpmn:task id="Task_6" name="Package and release module" />
    <bpmn:task id="Task_7" name="Rework failed module" />
    <bpmn:endEvent id="EndEvent_1" name="Module completed" />

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_4" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_6" name="Yes" sourceRef="Gateway_1" targetRef="Task_6" />
    <bpmn:sequenceFlow id="Flow_7" name="No" sourceRef="Gateway_1" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_7" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_6" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Manufacture_Modules">
    <bpmndi:BPMNPlane id="BPMNPlane_Manufacture_Modules" bpmnElement="process_manufacture_modules">
      <bpmndi:BPMNShape id="Lane_Planning_di" bpmnElement="Lane_Planning" isHorizontal="true">
        <dc:Bounds x="80" y="100" width="1460" height="110" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Production_di" bpmnElement="Lane_Production" isHorizontal="true">
        <dc:Bounds x="80" y="210" width="1460" height="110" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Quality_di" bpmnElement="Lane_Quality" isHorizontal="true">
        <dc:Bounds x="80" y="320" width="1460" height="110" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="130" y="137" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
        <dc:Bounds x="210" y="115" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="450" y="115" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_3_di" bpmnElement="Task_3">
        <dc:Bounds x="700" y="225" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="950" y="225" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="1200" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_6_di" bpmnElement="Task_6">
        <dc:Bounds x="1290" y="325" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_7_di" bpmnElement="Task_7">
        <dc:Bounds x="1210" y="225" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1460" y="347" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="166" y="155" />
        <di:waypoint x="210" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="155" />
        <di:waypoint x="450" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="640" y="155" />
        <di:waypoint x="760" y="155" />
        <di:waypoint x="760" y="225" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="900" y="265" />
        <di:waypoint x="950" y="265" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="1150" y="265" />
        <di:waypoint x="1225" y="265" />
        <di:waypoint x="1225" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1250" y="360" />
        <di:waypoint x="1290" y="365" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1225" y="335" />
        <di:waypoint x="1225" y="305" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1210" y="265" />
        <di:waypoint x="800" y="265" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1500" y="365" />
        <di:waypoint x="1460" y="365" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
