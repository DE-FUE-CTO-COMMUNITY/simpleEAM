# Logo- und Theme-Konfiguration für Simple-EAM
# Diese Datei dient als Beispiel für die dynamische Konfiguration

# =============================================================================
# LOGO-KONFIGURATION
# =============================================================================

# Standardkonfiguration für Simple-EAM Logo
NEXT_PUBLIC_LOGO_PATH=/images/Simple-EAM-Logo.png
NEXT_PUBLIC_LOGO_NAME=Simple-EAM

# Alternative Konfiguration für Atos Logo
# NEXT_PUBLIC_LOGO_PATH=/images/Atos-Logo.png
# NEXT_PUBLIC_LOGO_NAME=Atos

# Alternative Konfiguration für andere Logos
# NEXT_PUBLIC_LOGO_PATH=/images/DIN-Logo.png
# NEXT_PUBLIC_LOGO_NAME=DIN

# NEXT_PUBLIC_LOGO_PATH=/images/MF2-Logo.png
# NEXT_PUBLIC_LOGO_NAME=MF2

# =============================================================================
# THEME-KONFIGURATION (FARBEN UND SCHRIFTARTEN)
# =============================================================================

# Standard Theme (Atos Corporate Design)
NEXT_PUBLIC_THEME_PRIMARY_COLOR=#0066CC
NEXT_PUBLIC_THEME_SECONDARY_COLOR=#00AEEF
NEXT_PUBLIC_THEME_FONT_FAMILY="Roboto", "Helvetica", "Arial", sans-serif

# Alternative Theme-Konfigurationen:

# DIN Corporate Design
# NEXT_PUBLIC_THEME_PRIMARY_COLOR=#004164
# NEXT_PUBLIC_THEME_SECONDARY_COLOR=#821E3C
# NEXT_PUBLIC_THEME_FONT_FAMILY="Roboto", "Helvetica", "Arial", sans-serif

# MF2 Corporate Design  
# NEXT_PUBLIC_THEME_PRIMARY_COLOR=#c9ece1
# NEXT_PUBLIC_THEME_SECONDARY_COLOR=#2765c3
# NEXT_PUBLIC_THEME_FONT_FAMILY="Roboto", "Helvetica", "Arial", sans-serif

# Custom Theme Example
# NEXT_PUBLIC_THEME_PRIMARY_COLOR=#1976D2
# NEXT_PUBLIC_THEME_SECONDARY_COLOR=#DC004E
# NEXT_PUBLIC_THEME_FONT_FAMILY="Open Sans", "Helvetica", "Arial", sans-serif

# =============================================================================
# LEGACY-UNTERSTÜTZUNG (optional, alternative Variablennamen)
# =============================================================================

# Legacy Logo-Konfiguration (wird verwendet, wenn NEXT_PUBLIC_LOGO_PATH nicht gesetzt ist)
# NEXT_PUBLIC_LOGO_URL=/images/Simple-EAM-Logo.png
# NEXT_PUBLIC_LOGO_ALT=Simple-EAM

# Legacy Theme-Konfiguration (wird verwendet, wenn NEXT_PUBLIC_THEME_* nicht gesetzt ist)
# NEXT_PUBLIC_PRIMARY_COLOR=#0066CC
# NEXT_PUBLIC_SECONDARY_COLOR=#00AEEF
# NEXT_PUBLIC_FONT_FAMILY="Roboto", "Helvetica", "Arial", sans-serif
